<TopicScreen>
    BoxLayout:
        orientation: "vertical"
        spacing: 20
        padding: 40

        Label:
            id: title_label
            text: "Выберите формулу"
            font_size: "24sp"
            size_hint_y: None
            height: self.texture_size[1]

            halign: "center"
            valign: "middle"
            text_size: self.width, None
            padding_x: 20
            padding_y: 10

        TextInput:
            id: text_input
            size_hint_y:None
            height:40
            hint_text:"Поиск формулы..."
            multiline:False
            on_text: root.filter_formulas(self.text)
        
        ScrollView:
            GridLayout:
                id: formulas_grid
                cols: 1
                spacing: 10
                size_hint_y: None
                padding: 40
                height: self.minimum_height

        Button:
            text: "<- Назад"
            size_hint_y: None
            height: 60
            on_press: root.go_back()
