#:import Window kivy.core.window.Window
<MainScreen>:
    FloatLayout:
        spacing: 20
        padding: 40
        
        Widget:
            size_hint_y: 0.2 

        Label:
            text: "Выберите предмет"
            font_size: "75sp"

            size_hint_y: None
            height: 100

            halign: "center"
            valign: "middle"

            text_size: self.width, self.height

            color: 0,0,0,1
            bold: True

            pos_hint: {"top": 0.90}
            

        AnchorLayout:
            anchor_x: "center"
            anchor_y: "center"

            BoxLayout:
                id: subjects_box
                size: 845, 592
                size_hint: None, None
                orientation: "vertical"
                spacing: 10
                padding: 10

<RoundButton>:
    size_hint: (None, None)
    width: Window.width*0.439
    height: Window.height*0.12
    background_normal: ''
    background_color: (0,0,0,0)
    font_size: "32sp"
    canvas.before:
        Color:
            rgba: self.bg_color
        RoundedRectangle:
            size: self.size
            pos: self.pos 
            radius: [self.height/2] * 4
