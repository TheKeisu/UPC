<MainScreen>:

    BoxLayout:
        orientation: "vertical"
        spacing: 20
        padding: 40

        Label:
            text: "Выберите предмет"
            font_size: "32sp"
            size_hint_y: .2
            height: self.texture_size[1]
            
            halign: "center"
            valign: "middle"
            text_size: self.width, None
            padding_x: 20
            padding_y: 10


        BoxLayout:
            id: subjects_box
            orientation: "vertical"
            spacing: 10