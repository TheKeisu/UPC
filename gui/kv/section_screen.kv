<SectionScreen>
    BoxLayout:
        orientation: "vertical"
        spacing: 20
        padding: 40

        Label:
            id: title_label
            text: "Выберите раздел"
            font_size: "28sp"
            size_hint: (1, .2)
            height: self.texture_size[1]

            halign: "center"
            valign: "middle"
            text_size: self.width, None
            padding_x: 20
            padding_y: 10

        BoxLayout:
            id: sections_box
            orientation: "vertical"
            spacing: 10

        Button:
            text: "<- Назад"
            size_hint_y: None
            height: 60
            on_press: root.go_back()