<RoundButton>:
    size_hint: (None, None)
    background_normal: ''
    background_color: (0, 0, 0, 0)
    font_size: "32sp"

    canvas.before:
        Color:
            rgba: self.bg_color
        RoundedRectangle:
            size: self.size
            pos: self.pos
            radius: [self.height/2] * 4