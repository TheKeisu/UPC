<FormulaScreen>:
    FloatLayout:
        canvas.before:
            Color:
                rgba: 1, 1, 1, 1
            Rectangle:
                size: self.size
                pos: self.pos
                size: self.size

        # Кнопка назад всегда в углу
        BackButton:
            size_hint: None, None
            size: 100, 100
            pos_hint: {"x": 0.02, "top": 0.95}
            on_press: root.go_back()

        BoxLayout:
            orientation: "vertical"
            size_hint: (0.5, 0.9)
            pos_hint: {"center_x": 0.5, "center_y": 0.5}
            spacing: 30

            Label:
                id: title_label
                font_size: "40sp"
                size_hint_y: None
                height: self.texture_size[1] + 20
                text_size: self.width, None
                color: 0, 0, 0, 1
                bold: True
                pos_hint: {"top": 0.90,}
                halign: "center"
                valign: "middle"
            

            # Контейнер для теории (синий бокс)
            BoxLayout:
                id: information_box
                orientation: "vertical"
                size_hint_y: None
                height: self.minimum_height if self.children else 0
                opacity: 1 if self.children else 0
                padding: 30
                spacing: 20
                canvas.before:
                    Color:
                        rgba: 0.75, 0.8, 0.9, 1
                    RoundedRectangle:
                        size: self.size
                        pos: self.pos
                        radius: [20]
                # ... (Label для описания и формулы остаются прежними)
                Label:
                    id: description_label
                    size_hint_y: None
                    height: self.texture_size[1]
                    text_size: self.width, None
                    font_size: "35sp"
                    halign: "center"
                    color: 0,0,0,1

                Label:
                    id: formula_label
                    size_hint_y: None
                    height: self.texture_size[1]
                    text_size: self.width, None
                    font_size: "35sp"
                    bold: True
                    halign: "center"
                    color: 0,0,0,1


            # Единая область прокрутки для кнопок и инпутов
            ScrollView:
                size_hint_y: 1
                BoxLayout:
                    id: dynamic_content_area # Общая обертка
                    orientation: "vertical"
                    size_hint_y: None
                    height: self.minimum_height

                    GridLayout:
                        id: cases_container
                        cols: 1
                        size_hint_y: None
                        height: self.minimum_height
                        spacing: 20

                    GridLayout:
                        id: inputs_container
                        cols: 1
                        size_hint_y: None
                        height: self.minimum_height if self.opacity > 0 else 0
                        spacing: 20
                        opacity: 0
                        disabled: True

            # Нижний бокс результата (фиксированная высота)
            BoxLayout:
                id: result_box
                size_hint_y: None
                height: 100 if self.opacity > 0 else 0
                opacity: 0
                # ... (дизайн бокса результата)
                Label:
                    id: result_label
                    text_size: self.width, None
                    halign: "center"
                    bold: True
                    color: 0,0,0,1

<FormulaTextInput>:
    FloatLayout:
        size_hint_y: None

        canvas.before:
            Color:
                rgba: 0.75, 0.8, 0.95, 1
            RoundedRectangle:
                size: self.size
                pos: self.pos
                radius: [25]
    TextInput:
        multiline: False
        size_hint: (1, None) # 1 означает "всю ширину выделенных 80% экрана"
        height: 60
        font_size: "30sp"
        hint_text: "СИ..."
        bold: True
        padding: [20, 10, 20, 10]
        background_normal: ""
        background_color: (0,0,0,0)
        foreground_color: (0, 0.4, 0.8, 1)
        cursor_color: (0, 0.4, 0.8, 1) 