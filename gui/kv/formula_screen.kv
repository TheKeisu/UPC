<FormulaScreen>
    BoxLayout:
        orientation: "vertical"
        spacing: 5
        padding: 40

        Label:
            id: title_label
            text: ""
            font_size: "24sp"
            size_hint_y: None
            height: self.texture_size[1]
            halign: "center"
            valign: "middle"
            text_size: self.width, None
            padding_x: 0
            padding_y: 0

        Label:
            id: description_label
            text: ""
            font_size: "15sp"
            size_hint_y: None
            height: self.texture_size[1]
            halign: "center"
            valign: "middle"
            text_size: self.width, None
            padding_x: 20
            padding_y: 2

        Label:
            id: formula_label
            text: ""
            font_size: "20sp"
            size_hint_y: None
            height: self.texture_size[1]
            halign: "center"
            valign: "middle"
            text_size: self.width, None
            padding_x: 20
            padding_y: 2

        GridLayout:
            id: cases_container
            cols: 1
            size_hint_y: None
            height: self.minimum_height
            spacing: 20

        GridLayout:
            id: inputs_container
            cols: 1
            size_hint_y: None
            height: self.minimum_height
            spacing: 10
            opacity:20
            disabled: True

        Label:
            id: result_label
            text: ""

        Button:
            text: "<- Назад"
            size_hint_y: None
            height: 50
            on_press: root.go_back()